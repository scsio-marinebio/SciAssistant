# Custom LLM Service Configuration
MODEL_REQUEST_URL=
MODEL_REQUEST_TOKEN=your-service-token
MODEL_NAME=

# MCP Server Configuration
MCP_SERVER_URL=http://localhost:6274/mcp
MCP_AUTH_TOKEN=
MCP_USE_STDIO=true

# Agent Iteration Limits
PLANNER_MAX_ITERATION=20
INFORMATION_SEEKER_MAX_ITERATION=35
WRITER_MAX_ITERATION=30

# Mode
PLANNER_MODE=writing # auto, writing, qa

# Search Engine Configuration
SEARCH_ENGINE_BASE_URL=https://google.serper.dev/search
SEARCH_ENGINE_API_KEYS=

# URL Crawler Configuration
URL_CRAWLER_BASE_URL=https://r.jinaai.cn
URL_CRAWLER_API_KEYS=
URL_CRAWLER_MAX_TOKENS=100000

# Tool Trajectory and Output Paths
TRAJECTORY_STORAGE_PATH=./workspace
REPORT_OUTPUT_PATH=./report
DOCUMENT_ANALYSIS_PATH=./doc_analysis

# RAG Knowledge Base Configuration
RAG_API_URL=
RAG_APP_CODE=
RAG_DEFAULT_REPO_ID=
RAG_DEFAULT_PAGE_SIZE=20
SEARCH_SOURCE_RAG=false     # 是否使用RAG知识库，未配置，默认为开启

# General Settings
DEBUG_MODE=false
MAX_RETRIES=3
TIMEOUT=45